# ── Required ──────────────────────────────────────────────────────────────────
UP_BANK_TOKEN=up:yeah:your_token_here
ACTUAL_PASSWORD=your_actual_password
ACTUAL_SERVER_URL=http://192.168.1.x:5006
ACTUAL_SYNC_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Sync behaviour (optional — defaults shown) ────────────────────────────────
# How often to poll in hours (1–24, default: 3)
POLL_INTERVAL_HOURS=3
# How many days back to fetch transactions on each poll (1–90, default: 30)
LOOKBACK_DAYS=30

# ── Account mapping (Up account ID → Actual account name) ─────────────────────
# Run --list-accounts first to find your IDs, then fill these in.
# Add or remove numbered pairs as needed.
ACCOUNT_1_UP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ACCOUNT_1_ACTUAL=Your Account Name

ACCOUNT_2_UP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ACCOUNT_2_ACTUAL=Your Account Name

ACCOUNT_3_UP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ACCOUNT_3_ACTUAL=Your Account Name

# ── Telegram (optional) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
